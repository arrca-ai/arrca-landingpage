---
interface Props {
  id?: string;
  index?: string;
  eyebrow?: string;
  title?: string;
  dark?: boolean;
  class?: string;
}
const { id, index, eyebrow, title, dark = false, class: klass = "" } = Astro.props;
---
<section id={id} class={klass}>
  <div class="mx-auto max-w-[1180px] px-8 py-24">
    {(index || eyebrow) && (
      <div class="mb-3.5 flex items-baseline gap-4">
        {index && <span class={`font-mono text-xs tracking-wide ${dark ? "text-teal-400" : "text-teal-600"}`}>{index}</span>}
        {eyebrow && <span class="font-mono text-[11.5px] uppercase tracking-[0.14em] text-ink-400">{eyebrow}</span>}
      </div>
    )}
    {title && (
      <h2 class={`max-w-[22ch] text-[clamp(30px,4vw,42px)] font-bold leading-[1.05] tracking-[-0.03em] ${dark ? "text-paper" : "text-ink-900"}`}>{title}</h2>
    )}
    <slot />
  </div>
</section>
