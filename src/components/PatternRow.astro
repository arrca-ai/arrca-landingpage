---
interface Props {
  name: string;
  /** May contain inline HTML (e.g. <code>…</code>). */
  problem: string;
  query: string;
  first?: boolean;
}
const { name, problem, query, first = false } = Astro.props;
---
<div class={`grid grid-cols-1 items-start gap-3 py-[22px] sm:grid-cols-[0.9fr_1.5fr_0.9fr] sm:gap-7 ${first ? "border-t border-ink-200" : "border-t border-ink-100"}`}>
  <span class="text-base font-semibold tracking-[-0.01em] text-ink-900">{name}</span>
  <span class="text-[14.5px] leading-[1.55] text-ink-600" set:html={problem}></span>
  <span class="font-mono text-[12.5px] leading-snug text-teal-600">{query}</span>
</div>
