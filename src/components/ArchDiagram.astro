---
// Dark-theme architecture flow. Mirrors README:
// K8s API -> graph-k8s --\
//                          >-- Redis <-- graph-read -> REST + MCP
// OTel Collector -> graph-otel --/
// Designed to sit inside the dark "How it works" section.
---
<svg viewBox="0 0 880 260" class="w-full" role="img" aria-label="arrca architecture">
  <defs>
    <marker id="ar" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
      <path d="M0 0 L6 3 L0 6 Z" fill="#14b8a6" />
    </marker>
  </defs>
  <g font-family="var(--font-mono, monospace)">
    <rect x="8" y="42" width="170" height="56" rx="10" fill="none" stroke="#33485a" stroke-width="1.4" />
    <text x="26" y="68" fill="#fbfcfd" font-size="14" font-weight="600">Kubernetes API</text>
    <text x="26" y="86" fill="#7f93a1" font-size="11">pods, nodes, …</text>

    <rect x="8" y="162" width="170" height="56" rx="10" fill="none" stroke="#33485a" stroke-width="1.4" />
    <text x="26" y="188" fill="#fbfcfd" font-size="14" font-weight="600">OTel Collector</text>
    <text x="26" y="206" fill="#7f93a1" font-size="11">trace spans</text>

    <rect x="268" y="42" width="170" height="56" rx="10" fill="#13283a" stroke="#33485a" stroke-width="1.4" />
    <text x="286" y="68" fill="#fbfcfd" font-size="14" font-weight="600">graph-k8s</text>
    <text x="286" y="86" fill="#7f93a1" font-size="11">structure · single writer</text>

    <rect x="268" y="162" width="170" height="56" rx="10" fill="#13283a" stroke="#33485a" stroke-width="1.4" />
    <text x="286" y="188" fill="#fbfcfd" font-size="14" font-weight="600">graph-otel</text>
    <text x="286" y="206" fill="#7f93a1" font-size="11">relationships</text>

    <rect x="528" y="102" width="150" height="56" rx="10" fill="#13283a" stroke="#14b8a6" stroke-width="1.4" />
    <text x="603" y="128" fill="#fbfcfd" font-size="14" font-weight="600" text-anchor="middle">Redis</text>
    <text x="603" y="146" fill="#7f93a1" font-size="11" text-anchor="middle">the graph</text>

    <rect x="722" y="102" width="150" height="56" rx="10" fill="none" stroke="#33485a" stroke-width="1.4" />
    <text x="742" y="128" fill="#fbfcfd" font-size="14" font-weight="600">graph-read</text>
    <text x="742" y="146" fill="#7f93a1" font-size="11">REST + MCP</text>

    <g stroke="#14b8a6" stroke-width="1.6" fill="none" marker-end="url(#ar)">
      <path d="M178 70 L262 70" />
      <path d="M178 190 L262 190" />
      <path d="M438 70 Q500 70 524 116" />
      <path d="M438 190 Q500 190 524 144" />
      <path d="M678 130 L716 130" />
    </g>
  </g>
</svg>
